# NeuroPD environment variables (example).
# Copy to `.env` (which is git-ignored) and fill in as needed. Never commit `.env`
# or place secrets in code, notebooks, logs, or prompts (spec Section 25).

# Logging verbosity for the neuropd logger (DEBUG, INFO, WARNING, ERROR).
NEUROPD_LOG_LEVEL=INFO

# Root directory for datasets. Defaults to ./data if unset. Raw data live under
# ${NEUROPD_DATA_DIR}/raw and are git-ignored.
# NEUROPD_DATA_DIR=./data
